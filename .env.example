# brokerHub Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# Database
# ===========================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/brokerhub
DATABASE_POOL_SIZE=10
DATABASE_MAX_CONNECTIONS=20

# ===========================================
# Redis
# ===========================================
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=brokerhub:

# ===========================================
# JWT Authentication
# ===========================================
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
JWT_ISSUER=brokerhub-platform

# ===========================================
# API Configuration
# ===========================================
API_PORT=3000
API_HOST=0.0.0.0
API_RATE_LIMIT_DEFAULT=100
API_RATE_LIMIT_WINDOW_MS=3600000

# ===========================================
# S3 Storage (Documents)
# ===========================================
S3_BUCKET=brokerhub-documents
S3_REGION=ap-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_ENDPOINT_URL=  # Leave empty for AWS, set for MinIO/compatible

# ===========================================
# Credit System
# ===========================================
CREDIT_GRACE_PERIOD_HOURS=24
CREDIT_ZERO_SUSPEND_AFTER_HOURS=72

# ===========================================
# Audit & Compliance
# ===========================================
AUDIT_LOG_RETENTION_YEARS=7
AUDIT_LOG_IMMUTABLE=true

# ===========================================
# Brand (Default)
# ===========================================
BRAND_PRIMARY_COLOR=#0A192F
BRAND_ACCENT_COLOR=#00D4FF
BRAND_TAGLINE=Your 24/7 AI Admin

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=info
LOG_FORMAT=json

# ===========================================
# Feature Flags
# ===========================================
FEATURE_WHITE_LABEL_ENABLED=true
FEATURE_AUTO_TOPUP_ENABLED=false
